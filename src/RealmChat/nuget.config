<?xml version="1.0" encoding="utf-8"?>
<!-- Pin the package source explicitly so the build works regardless of the
     machine's global NuGet configuration (only the net48 reference-assembly
     package is pulled; it is build-time only). -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
